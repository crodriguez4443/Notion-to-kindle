# Copy this file to .env and fill in your values for local testing.
# NEVER commit .env to git.

# Notion integration token — from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your Notion database (found in the database URL)
# e.g. https://www.notion.so/yourworkspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                                           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ this part
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail address used to send emails to Kindle
GMAIL_USER=you@gmail.com

# Google App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your Kindle email address
# Found at: Amazon → Manage Your Content and Devices → Devices → [your Kindle]
KINDLE_EMAIL=you@kindle.com
